# Copy to .env.local and fill in real values. Never commit .env.local.

# MongoDB Atlas connection string
MONGODB_URI=

# Long random string for signing auth tokens
JWT_SECRET=

# Optional: shared passphrase the Sweep Desk API requires (see DEPLOYMENT.md)
SWEEPDESK_KEY=

# Optional: lock the Sweep Desk API's CORS to one origin (default *)
SWEEPDESK_ALLOWED_ORIGIN=
